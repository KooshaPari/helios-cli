      "integration": "bazel_module_override",
      "module_reference": "//patches:toolchains_llvm_bootstrapped_resource_dir.patch",
      "secondary_policy": "prefer_primary"
    },
    {
      "id": "aws_lc_sys_memcmp_check",
      "category": "platform-linker",
